{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceRoot}",
                "${workspaceRoot}/PDCursesMod",
                "/usr/include",
                "/usr/include/python3.11",
                "."
            ],
            "defines": [
                "HAVE_NCURSESW",
                "HAVE_VSNPRINTF",
                "HAVE_VSSCANF",
                "PDC_FORCE_UTF8",
                "PDC_WIDE",
                "_DEBUG",
                "_XOPEN_SOURCE_EXTENDED",
                "_FILE_OFFSET_BITS=64"
            ],
            "browse": {
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": "",
                "path": [
                    "/usr/include"
                ]
            },
            "intelliSenseMode": "clang-x64",
            "compilerPath": "/usr/bin/clang",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}